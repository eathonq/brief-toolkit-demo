{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": ".schema.json",
  "title": "i18n locale file",
  "type": "object",
  "required": [
    "meta"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "title": "多语言文本Meta信息",
      "required": [
        "code",
        "name"
      ],
      "properties": {
        "code": {
          "type": "string",
          "title": "多语言编码（也是多语言文件名称，图片目录名称）"
        },
        "name": {
          "type": "string",
          "title": "多语言名称"
        },
        "version": {
          "type": "string",
          "title": "多语言版本"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}